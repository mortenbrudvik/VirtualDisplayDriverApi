<Window x:Class="VirtualDisplayDriver.ExampleApp.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:VirtualDisplayDriver.ExampleApp.ViewModels"
        xmlns:views="clr-namespace:VirtualDisplayDriver.ExampleApp.Views"
        xmlns:converters="clr-namespace:VirtualDisplayDriver.ExampleApp.Converters"
        Title="Virtual Display Driver — Dashboard"
        Width="1000" Height="680"
        MinWidth="800" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BackgroundPrimary}">

    <Window.Resources>
        <converters:BoolToBrushConverter x:Key="BoolToBrush" />
        <converters:BoolToStatusConverter x:Key="PipeStatus" TrueText="Pipe: Running" FalseText="Pipe: Stopped" />
        <converters:BoolToStatusConverter x:Key="DriverStatus" TrueText="Driver: Installed" FalseText="Driver: Not Found" />

        <DataTemplate DataType="{x:Type vm:StatusViewModel}">
            <views:StatusView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:DisplayManagementViewModel}">
            <views:DisplayManagementView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:GpuViewModel}">
            <views:GpuView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:ActivityLogViewModel}">
            <views:ActivityLogView />
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Grid.Row="0"
                Background="{StaticResource BackgroundTertiary}"
                BorderBrush="{StaticResource SurfaceBorder}"
                BorderThickness="0,0,1,0">
            <DockPanel>
                <!-- App Title -->
                <StackPanel DockPanel.Dock="Top" Margin="16,20,16,16">
                    <TextBlock Text="VDD Dashboard"
                               FontSize="18" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimary}" />
                    <TextBlock Text="Virtual Display Driver"
                               FontSize="11"
                               Foreground="{StaticResource TextDim}"
                               Margin="0,2,0,0" />
                </StackPanel>

                <!-- Sidebar Status Card -->
                <Border DockPanel.Dock="Bottom"
                        Background="{StaticResource BackgroundSecondary}"
                        CornerRadius="8"
                        Margin="12,0,12,12"
                        Padding="12,10">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="8" Height="8"
                                     Fill="{Binding IsPipeRunning, Converter={StaticResource BoolToBrush}}"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding IsPipeRunning, Converter={StaticResource PipeStatus}}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondary}" />
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="8" Height="8"
                                     Fill="{Binding IsDriverInstalled, Converter={StaticResource BoolToBrush}}"
                                     Margin="0,0,8,0"
                                     VerticalAlignment="Center" />
                            <TextBlock Text="{Binding IsDriverInstalled, Converter={StaticResource DriverStatus}}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondary}" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Navigation -->
                <ListBox AutomationProperties.AutomationId="NavListBox"
                         ItemsSource="{Binding NavigationItems}"
                         SelectedItem="{Binding SelectedNavigationItem}"
                         Style="{StaticResource NavListBox}"
                         Margin="0,4,0,0">
                    <ListBox.ItemContainerStyle>
                        <Style TargetType="ListBoxItem" BasedOn="{StaticResource NavListBoxItem}" />
                    </ListBox.ItemContainerStyle>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding Icon}"
                                           FontFamily="Segoe MDL2 Assets"
                                           FontSize="16"
                                           VerticalAlignment="Center"
                                           Margin="0,0,12,0" />
                                <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

        <!-- Main Content Area -->
        <ContentControl AutomationProperties.AutomationId="ContentArea"
                        Grid.Column="1" Grid.Row="0"
                        Content="{Binding Navigation.CurrentViewModel}"
                        Margin="24,20,24,20" />

        <!-- Status Bar -->
        <Border Grid.Column="0" Grid.ColumnSpan="2" Grid.Row="1"
                Background="{StaticResource BackgroundSecondary}"
                BorderBrush="{StaticResource SurfaceBorder}"
                BorderThickness="0,1,0,0"
                Padding="16,6">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="6" Height="6"
                         Fill="{Binding IsPipeRunning, Converter={StaticResource BoolToBrush}}"
                         Margin="0,0,6,0"
                         VerticalAlignment="Center" />
                <TextBlock Text="{Binding IsPipeRunning, Converter={StaticResource PipeStatus}}"
                           FontSize="11" Foreground="{StaticResource TextDim}"
                           Margin="0,0,16,0" />

                <TextBlock Text="{Binding IsDriverInstalled, Converter={StaticResource DriverStatus}}"
                           FontSize="11" Foreground="{StaticResource TextDim}"
                           Margin="0,0,16,0" />

                <TextBlock FontSize="11" Foreground="{StaticResource TextDim}">
                    <TextBlock.Text>
                        <Binding Path="InstallPath" StringFormat="Path: {0}" FallbackValue="Path: N/A" />
                    </TextBlock.Text>
                </TextBlock>
            </StackPanel>
        </Border>
    </Grid>
</Window>
