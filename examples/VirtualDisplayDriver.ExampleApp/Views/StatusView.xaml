<UserControl x:Class="VirtualDisplayDriver.ExampleApp.Views.StatusView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VirtualDisplayDriver.ExampleApp.Converters">

    <UserControl.Resources>
        <converters:BoolToBrushConverter x:Key="BoolToBrush" />
        <converters:BoolToStatusConverter x:Key="BoolYesNo" TrueText="Yes" FalseText="No" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Header -->
            <TextBlock AutomationProperties.AutomationId="StatusHeader" Text="Status Overview" FontSize="22" FontWeight="Bold" Margin="0,0,0,4" />
            <TextBlock Text="Driver health and connection information"
                       Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,0,0,20" />

            <!-- Install Banner -->
            <Border AutomationProperties.AutomationId="InstallBanner"
                    Background="#3389B4FA" CornerRadius="6" Padding="16,12" Margin="0,0,0,12"
                    Visibility="{Binding ShowInstallBanner, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <Button AutomationProperties.AutomationId="InstallDriverButton"
                            DockPanel.Dock="Right" Content="Install Driver"
                            Command="{Binding InstallDriverCommand}"
                            IsEnabled="{Binding IsSetupInProgress, Converter={StaticResource InverseBool}}"
                            Margin="12,0,0,0" VerticalAlignment="Center" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Driver Not Installed" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="The Virtual Display Driver is not detected on this system."
                                   Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Reinstall Banner (device has error) -->
            <Border AutomationProperties.AutomationId="ReinstallBanner"
                    Background="#33F38BA8" CornerRadius="6" Padding="16,12" Margin="0,0,0,12"
                    Visibility="{Binding ShowReinstallBanner, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <Button AutomationProperties.AutomationId="ReinstallDriverButton"
                            DockPanel.Dock="Right" Content="Reinstall Driver"
                            Command="{Binding ReinstallDriverCommand}"
                            IsEnabled="{Binding IsSetupInProgress, Converter={StaticResource InverseBool}}"
                            Margin="12,0,0,0" VerticalAlignment="Center" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Driver Error" FontWeight="SemiBold" FontSize="14"
                                   Foreground="{StaticResource AccentError}" />
                        <TextBlock Text="The driver has a problem (Code 43). Reinstalling may fix this."
                                   Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Enable/Restart Banner -->
            <Border AutomationProperties.AutomationId="EnableBanner"
                    Background="#33F9E2AF" CornerRadius="6" Padding="16,12" Margin="0,0,0,12"
                    Visibility="{Binding ShowEnableBanner, Converter={StaticResource BoolToVis}}">
                <DockPanel>
                    <Button AutomationProperties.AutomationId="EnableDriverButton"
                            DockPanel.Dock="Right" Content="Start Driver"
                            Command="{Binding EnableDriverCommand}"
                            IsEnabled="{Binding IsSetupInProgress, Converter={StaticResource InverseBool}}"
                            Margin="12,0,0,0" VerticalAlignment="Center" />
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Driver Not Running" FontWeight="SemiBold" FontSize="14" />
                        <TextBlock Text="The driver is installed but not responding. Click to enable or restart."
                                   Foreground="{StaticResource TextSecondary}" FontSize="12" Margin="0,4,0,0" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Setup Progress -->
            <Border AutomationProperties.AutomationId="SetupProgress"
                    Background="#3389B4FA" CornerRadius="6" Padding="16,12" Margin="0,0,0,12"
                    Visibility="{Binding IsSetupInProgress, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="{Binding SetupProgressMessage}" FontSize="12" Margin="0,0,0,8" />
                    <ProgressBar Value="{Binding SetupProgressPercent}" Maximum="1.0" Height="4" />
                </StackPanel>
            </Border>

            <!-- Loading -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                         Margin="0,0,0,12" />

            <!-- Error -->
            <Border Background="#33F38BA8" CornerRadius="6" Padding="12,8" Margin="0,0,0,12"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource AccentError}" TextWrapping="Wrap" />
            </Border>

            <!-- Stat Cards Grid -->
            <UniformGrid Columns="2" Margin="0,0,0,16">
                <!-- Pipe Running -->
                <Border Style="{StaticResource Card}" Margin="0,0,8,8">
                    <StackPanel>
                        <TextBlock Text="PIPE STATUS" FontSize="10" Foreground="{StaticResource TextDim}" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Ellipse Width="12" Height="12"
                                     Fill="{Binding IsPipeRunning, Converter={StaticResource BoolToBrush}}"
                                     Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock AutomationProperties.AutomationId="PipeStatusValue"
                                       Text="{Binding IsPipeRunning, Converter={StaticResource BoolYesNo}}"
                                       FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Driver Installed -->
                <Border Style="{StaticResource Card}" Margin="8,0,0,8">
                    <StackPanel>
                        <TextBlock Text="DRIVER INSTALLED" FontSize="10" Foreground="{StaticResource TextDim}" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Ellipse Width="12" Height="12"
                                     Fill="{Binding IsDriverInstalled, Converter={StaticResource BoolToBrush}}"
                                     Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock AutomationProperties.AutomationId="DriverInstalledValue"
                                       Text="{Binding IsDriverInstalled, Converter={StaticResource BoolYesNo}}"
                                       FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Connected -->
                <Border Style="{StaticResource Card}" Margin="0,0,8,8">
                    <StackPanel>
                        <TextBlock Text="CONNECTED" FontSize="10" Foreground="{StaticResource TextDim}" FontWeight="SemiBold" />
                        <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                            <Ellipse Width="12" Height="12"
                                     Fill="{Binding IsConnected, Converter={StaticResource BoolToBrush}}"
                                     Margin="0,0,8,0" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding IsConnected, Converter={StaticResource BoolYesNo}}"
                                       FontSize="20" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Display Count -->
                <Border Style="{StaticResource Card}" Margin="8,0,0,8">
                    <StackPanel>
                        <TextBlock Text="VIRTUAL DISPLAYS" FontSize="10" Foreground="{StaticResource TextDim}" FontWeight="SemiBold" />
                        <TextBlock AutomationProperties.AutomationId="DisplayCountValue" Text="{Binding DisplayCount}" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource AccentPrimary}" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Actions -->
            <StackPanel Orientation="Horizontal">
                <Button AutomationProperties.AutomationId="RestartDriverButton" Content="Restart Device"
                        Command="{Binding RestartDeviceCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                <Button AutomationProperties.AutomationId="DisableDriverButton" Content="Disable Driver"
                        Command="{Binding DisableDriverCommand}" Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                <Button AutomationProperties.AutomationId="UninstallDriverButton" Content="Uninstall Driver"
                        Command="{Binding UninstallDriverCommand}" Style="{StaticResource SecondaryButton}" />
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>
