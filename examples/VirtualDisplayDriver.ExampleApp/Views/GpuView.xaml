<UserControl x:Class="VirtualDisplayDriver.ExampleApp.Views.GpuView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VirtualDisplayDriver.ExampleApp.Converters">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:InverseBoolConverter x:Key="InverseBool" />
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel>
            <!-- Header -->
            <TextBlock AutomationProperties.AutomationId="GpuHeader" Text="GPU Management" FontSize="22" FontWeight="Bold" Margin="0,0,0,4" />
            <TextBlock Text="View GPU information and select which GPU hosts virtual displays"
                       Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,0,0,20" />

            <!-- Loading -->
            <ProgressBar IsIndeterminate="True"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVis}}"
                         Margin="0,0,0,12" />

            <!-- Error -->
            <Border Background="#33F38BA8" CornerRadius="6" Padding="12,8" Margin="0,0,0,12"
                    Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}, FallbackValue=Collapsed}">
                <TextBlock Text="{Binding ErrorMessage}" Foreground="{StaticResource AccentError}" TextWrapping="Wrap" />
            </Border>

            <!-- GPU Info Cards -->
            <UniformGrid Columns="3" Margin="0,0,0,16">
                <Border Style="{StaticResource Card}" Margin="0,0,8,0">
                    <StackPanel>
                        <TextBlock Text="D3D DEVICE GPU" FontSize="10" Foreground="{StaticResource TextDim}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding D3DDeviceGpu, FallbackValue='N/A'}"
                                   FontSize="13" Foreground="{StaticResource AccentPrimary}"
                                   TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="4,0,4,0">
                    <StackPanel>
                        <TextBlock Text="IDDCX VERSION" FontSize="10" Foreground="{StaticResource TextDim}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding IddCxVersion, FallbackValue='N/A'}"
                                   FontSize="13" Foreground="{StaticResource AccentPrimary}"
                                   Margin="0,8,0,0" />
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource Card}" Margin="8,0,0,0">
                    <StackPanel>
                        <TextBlock Text="ASSIGNED GPU" FontSize="10" Foreground="{StaticResource TextDim}" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding AssignedGpu, FallbackValue='N/A'}"
                                   FontSize="13" Foreground="{StaticResource AccentPrimary}"
                                   TextWrapping="Wrap" Margin="0,8,0,0" />
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- GPU Selection -->
            <Border Style="{StaticResource Card}" Margin="0,0,0,16">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="SELECT GPU" FontSize="10" Foreground="{StaticResource TextDim}" FontWeight="SemiBold" />
                        <Border Background="#33F9E2AF" CornerRadius="4" Padding="6,2" Margin="12,0,0,0">
                            <TextBlock Text="Triggers driver reload (30s cooldown)" FontSize="10"
                                       Foreground="{StaticResource AccentWarning}" />
                        </Border>
                    </StackPanel>
                    <Grid Margin="0,12,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ComboBox AutomationProperties.AutomationId="GpuComboBox" Grid.Column="0"
                                  ItemsSource="{Binding AllGpus}"
                                  SelectedItem="{Binding SelectedGpu}"
                                  IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}"
                                  Margin="0,0,12,0" />
                        <Button AutomationProperties.AutomationId="SetGpuButton" Grid.Column="1"
                                Content="Set GPU"
                                Command="{Binding SetGpuCommand}"
                                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBool}}" />
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Refresh -->
            <Button AutomationProperties.AutomationId="RefreshGpuButton" Content="Refresh GPU Info" Command="{Binding RefreshGpuInfoCommand}"
                    Style="{StaticResource SecondaryButton}" HorizontalAlignment="Left" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
