<UserControl x:Class="VirtualDisplayDriver.ExampleApp.Views.ActivityLogView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:VirtualDisplayDriver.ExampleApp.Converters">

    <UserControl.Resources>
        <converters:LogLevelToBrushConverter x:Key="LogLevelToBrush" />
    </UserControl.Resources>

    <DockPanel>
        <!-- Header -->
        <StackPanel DockPanel.Dock="Top">
            <TextBlock Text="Activity Log" FontSize="22" FontWeight="Bold" Margin="0,0,0,4" />
            <TextBlock Text="Real-time log of API calls, responses, and errors"
                       Foreground="{StaticResource TextSecondary}" FontSize="13" Margin="0,0,0,12" />

            <!-- Toolbar -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                <Button Content="Clear" Command="{Binding ClearLogCommand}"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,8,0" />
                <Button Content="Copy All" Command="{Binding CopyLogCommand}"
                        Style="{StaticResource SecondaryButton}" Margin="0,0,16,0" />
                <CheckBox IsChecked="{Binding AutoScroll}" VerticalAlignment="Center">
                    <TextBlock Text="Auto-scroll" Foreground="{StaticResource TextSecondary}" FontSize="12" />
                </CheckBox>
            </StackPanel>
        </StackPanel>

        <!-- Log List -->
        <Border Style="{StaticResource Card}" Padding="0">
            <ListBox ItemsSource="{Binding Entries}"
                     Background="Transparent"
                     BorderThickness="0"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     x:Name="LogListBox">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="12,6" />
                        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <Border x:Name="border"
                                            Background="Transparent"
                                            BorderThickness="0,0,0,1"
                                            BorderBrush="{StaticResource SurfaceBorder}"
                                            Padding="{TemplateBinding Padding}">
                                        <ContentPresenter />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="border" Property="Background"
                                                    Value="{StaticResource BackgroundTertiary}" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <DockPanel>
                            <!-- Timestamp -->
                            <TextBlock DockPanel.Dock="Left"
                                       Text="{Binding Timestamp, StringFormat='{}{0:HH:mm:ss.fff}'}"
                                       FontSize="11" FontFamily="Consolas"
                                       Foreground="{StaticResource TextDim}"
                                       VerticalAlignment="Top"
                                       Margin="0,0,10,0"
                                       MinWidth="85" />

                            <!-- Level dot -->
                            <Ellipse DockPanel.Dock="Left"
                                     Width="8" Height="8"
                                     Fill="{Binding Level, Converter={StaticResource LogLevelToBrush}}"
                                     VerticalAlignment="Top"
                                     Margin="0,4,8,0" />

                            <!-- Category tag -->
                            <Border DockPanel.Dock="Left"
                                    Background="{StaticResource BackgroundTertiary}"
                                    CornerRadius="3"
                                    Padding="6,1"
                                    VerticalAlignment="Top"
                                    Margin="0,0,10,0">
                                <TextBlock Text="{Binding Category}"
                                           FontSize="10" FontWeight="SemiBold"
                                           Foreground="{StaticResource TextSecondary}" />
                            </Border>

                            <!-- Message -->
                            <StackPanel>
                                <TextBlock Text="{Binding Message}"
                                           FontSize="12"
                                           Foreground="{StaticResource TextPrimary}"
                                           TextWrapping="Wrap" />
                                <TextBlock Text="{Binding Detail}"
                                           FontSize="11" FontFamily="Consolas"
                                           Foreground="{StaticResource TextDim}"
                                           TextWrapping="Wrap"
                                           Margin="0,2,0,0"
                                           Visibility="{Binding Detail, Converter={StaticResource NullToCollapsed}, FallbackValue=Collapsed}" />
                            </StackPanel>
                        </DockPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Border>
    </DockPanel>
</UserControl>
