<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Backgrounds -->
    <Color x:Key="BackgroundPrimaryColor">#FF1E1E2E</Color>
    <Color x:Key="BackgroundSecondaryColor">#FF2A2A3C</Color>
    <Color x:Key="BackgroundTertiaryColor">#FF363650</Color>
    <Color x:Key="SurfaceBorderColor">#FF44446A</Color>

    <SolidColorBrush x:Key="BackgroundPrimary" Color="{StaticResource BackgroundPrimaryColor}" />
    <SolidColorBrush x:Key="BackgroundSecondary" Color="{StaticResource BackgroundSecondaryColor}" />
    <SolidColorBrush x:Key="BackgroundTertiary" Color="{StaticResource BackgroundTertiaryColor}" />
    <SolidColorBrush x:Key="SurfaceBorder" Color="{StaticResource SurfaceBorderColor}" />

    <!-- Text -->
    <SolidColorBrush x:Key="TextPrimary" Color="#FFCDD6F4" />
    <SolidColorBrush x:Key="TextSecondary" Color="#FFA6ADC8" />
    <SolidColorBrush x:Key="TextDim" Color="#FF6C7086" />

    <!-- Accents -->
    <SolidColorBrush x:Key="AccentPrimary" Color="#FF89B4FA" />
    <SolidColorBrush x:Key="AccentHover" Color="#FF74A8F7" />
    <SolidColorBrush x:Key="AccentPressed" Color="#FF5B96F0" />
    <SolidColorBrush x:Key="AccentSuccess" Color="#FFA6E3A1" />
    <SolidColorBrush x:Key="AccentWarning" Color="#FFF9E2AF" />
    <SolidColorBrush x:Key="AccentError" Color="#FFF38BA8" />

    <!-- Shared values -->
    <CornerRadius x:Key="CardCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="ButtonCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="SmallCornerRadius">4</CornerRadius>
    <Thickness x:Key="CardPadding">16</Thickness>
    <Thickness x:Key="SectionSpacing">0,0,0,16</Thickness>

</ResourceDictionary>
